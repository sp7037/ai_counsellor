# =============================================================================
# AI Counsellor — environment template
# Copy to .env and fill in values. Never commit .env to Git.
# Local development: see documents/setup/LOCAL_SETUP.md
# cPanel staging: see documents/deployment/CPANEL_STAGING_DEPLOYMENT.md
# VPS production: see documents/deployment/VPS_PRODUCTION_DEPLOYMENT.md
# =============================================================================

# --- Application ---
APP_NAME="AI Counsellor"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_IN
APP_TIMEZONE=Asia/Kolkata

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (MySQL/MariaDB recommended for staging/production) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

# --- Session / cache / queue (cPanel-friendly defaults) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set true when APP_URL uses HTTPS:
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Redis (optional; recommended on VPS, often unavailable on shared cPanel) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (Module 12 not implemented; use log or SMTP for staging smoke tests) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@staging.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS / object storage (optional) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- AI / OpenAI ---
AI_DEFAULT_PROVIDER=openai
AI_REQUEST_TIMEOUT=15
AI_CONNECT_TIMEOUT=5
AI_RATE_LIMIT_MESSAGES=30,1
OPENAI_ENABLED=true
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_OUTPUT_TOKENS=400
# --- AI / DeepSeek (OpenAI-compatible API) ---
DEEPSEEK_ENABLED=true
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.2
DEEPSEEK_MAX_OUTPUT_TOKENS=400
# Disable fake AI on staging/production (tests enable via phpunit.xml):
FAKE_AI_ENABLED=false
FAKE_AI_MODEL=fake-model

# --- Subscriptions ---
SUBSCRIPTION_DEFAULT_GRACE_DAYS=7
SUBSCRIPTION_DEFAULT_TRIAL_DAYS=14

# --- Widget ---
WIDGET_SESSION_TTL_MINUTES=120
WIDGET_RATE_LIMIT_SESSION=20,1
WIDGET_RATE_LIMIT_MESSAGES=60,1
# Allow local dev origins only when testing widget locally:
WIDGET_ALLOW_LOCAL_ORIGINS=false

# --- Payments (Razorpay) ---
PAYMENT_DEFAULT_PROVIDER=razorpay
PAYMENT_ENVIRONMENT=test
PAYMENT_ORDER_EXPIRY_MINUTES=30
PAYMENT_PLATFORM_LEGAL_NAME="${APP_NAME}"
PAYMENT_CONNECT_TIMEOUT=5
PAYMENT_REQUEST_TIMEOUT=15
PAYMENT_WEBHOOK_RATE_LIMIT=120,1
PAYMENT_RECONCILIATION_BATCH=50
RAZORPAY_ENABLED=true
RAZORPAY_BASE_URL=https://api.razorpay.com/v1
RAZORPAY_KEY_ID=your-razorpay-test-key-id
RAZORPAY_KEY_SECRET=your-razorpay-test-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
# Webhook URL (configure in Razorpay dashboard):
# ${APP_URL}/webhooks/payments/razorpay
# Disable fake payment provider on staging/production:
FAKE_PAYMENT_ENABLED=false

# --- WhatsApp / Meta Cloud API ---
MESSAGING_DEFAULT_PROVIDER=meta
MESSAGING_ENVIRONMENT=test
MESSAGING_SERVICE_WINDOW_HOURS=24
MESSAGING_WEBHOOK_RATE_LIMIT=240,1
MESSAGING_CONNECT_TIMEOUT=5
MESSAGING_REQUEST_TIMEOUT=15
META_WHATSAPP_ENABLED=false
META_WHATSAPP_BASE_URL=https://graph.facebook.com/v21.0
META_WHATSAPP_GRAPH_VERSION=v21.0
# Webhook URL (configure in Meta developer app):
# ${APP_URL}/webhooks/messaging/meta
# Disable fake messaging provider on staging/production:
FAKE_MESSAGING_ENABLED=false
FAKE_MESSAGING_APP_SECRET=change-me-for-staging-fake-webhook-tests-only

# --- Conversations / widget polling ---
CONVERSATION_POLL_INTERVAL=5
CONVERSATION_MAX_POLL_MESSAGES=50
CONVERSATION_MAX_INITIAL_HISTORY=100
WIDGET_RATE_LIMIT_HANDOFF=10,1
WIDGET_RATE_LIMIT_POLL=120,1
